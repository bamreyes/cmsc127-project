{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "baseUrl": ".",
    "rootDir": "src",
    "paths": {
      "@/*": ["src/*"],
      "@shared": ["../shared/index.d.ts"],
      "@shared/*": ["../shared/*"]
    },

    "outDir": "./dist",
    "strict": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true,

    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "isolatedModules": true
  }
}
